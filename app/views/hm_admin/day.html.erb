<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'hm_timeclock', plugin: 'redmine_hm_cratchmere' %>
<% end %>

<div class="contextual">
  <%= link_to l(:label_hm_admin_back), hm_admin_path(month: @date.strftime('%Y-%m')), class: 'icon icon-back' %>
</div>

<h2><%= l(:label_hm_admin_day_title, date: I18n.l(@date)) %></h2>

<h3><%= l(:label_hm_admin_day_worktime) %></h3>
<% if @entries.empty? %>
  <p class="nodata"><%= l(:label_hm_admin_day_no_worktime) %></p>
<% else %>
  <table class="list">
    <thead>
      <tr>
        <th><%= l(:label_hm_admin_user) %></th>
        <th><%= l(:label_hm_timeclock_session_started_at) %></th>
        <th><%= l(:label_hm_timeclock_session_ended_at) %></th>
        <th><%= l(:label_hm_timeclock_break_today) %></th>
        <th><%= l(:label_hm_timeclock_worked_today) %></th>
        <th><%= l(:label_hm_timeclock_state) %></th>
      </tr>
    </thead>
    <tbody>
      <% @entries.each do |e| %>
        <tr>
          <td><%= link_to h(e.user.name), hm_admin_user_path(user_id: e.user_id) %></td>
          <td><%= format_time(e.started_at) %></td>
          <td><%= e.ended_at ? format_time(e.ended_at) : '—' %></td>
          <td><%= hm_format_seconds(e.total_break_seconds) %></td>
          <td><%= hm_format_seconds(e.net_seconds) %></td>
          <td><%= hm_state_label(e.state) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<h3><%= l(:label_hm_admin_day_absences) %></h3>
<% if @absences.empty? %>
  <p class="nodata"><%= l(:label_hm_admin_day_no_absences) %></p>
<% else %>
  <%= render partial: 'hm_timeclock/absence_list', locals: { absences: @absences, show_user: true } %>
<% end %>
